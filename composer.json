{
    "name": "digit7s/inertia-table",
    "description": "A backend-driven Inertia Datatable for Laravel and Vue 3",
    "license": "MIT",
    "authors": [
        {
            "name": "Digit7s",
            "email": "info@digit7s.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/database": "^10.0|^11.0|^12.0",
        "illuminate/console": "^10.0|^11.0|^12.0",
        "inertiajs/inertia-laravel": "^1.0|^2.0"
    },
    "autoload": {
        "psr-4": {
            "Digit7s\\InertiaTable\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Digit7s\\InertiaTable\\InertiaTableServiceProvider"
            ]
        }
    }
}
